{
  "name": "movie-finder-frontend",
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://northern-christiane-997education-aa9be067.koyeb.app/api/:path*"
    },
    {
      "source": "/ping",
      "destination": "https://northern-christiane-997education-aa9be067.koyeb.app/ping"
    }
  ],
  "env": {
    "VITE_API_URL": ""
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ]
}